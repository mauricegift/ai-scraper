# ─────────────────────────────────────────────────────────────────
# AI Playground — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
# Port the server listens on (default: 5000).
# Render and Railway set PORT automatically — leave blank on those platforms.
PORT=5000

# Enable Flask debug mode — NEVER use true in production
FLASK_DEBUG=false

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection URL.
# Leave blank to use the JSON file fallback (sessions_store.json).
#
# Local PostgreSQL (default port 5432):
#   DATABASE_URL=postgresql://username:password@localhost:5432/ai_playground
#
# Self-hosted VPS example:
#   DATABASE_URL=postgresql://aiuser:s3cretpass@192.168.1.10:5432/ai_playground
#
# Managed cloud (Supabase, Neon, Railway, Render, etc.):
#   DATABASE_URL=postgresql://user:pass@db.example.com:5432/dbname?sslmode=require
DATABASE_URL=

# ── HuggingFace ──────────────────────────────────────────────────
# Only required for HuggingFace models (DeepSeek, Llama, Qwen, etc.).
# Free models (Perplexity, PollinationsAI, YqCloud, Opera) do NOT need this.
#
# Get your token at https://huggingface.co/settings/tokens
# Read-only scope is sufficient.
HF_TOKEN=hf_your_token_here
